  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@opsflow.com\",\n  \"name\": \"Admin\",\n  \"lastname\": \"Root\",\n  \"password\": \"Admin123*\"\n}"
            },
            "url": "{{base_url}}/auth/signup"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login responde 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let jsonData = {};",
                  "try {",
                  "  jsonData = pm.response.json();",
                  "} catch (e) {",
                  "  console.log('La respuesta no es JSON', e);",
                  "}",
                  "",
                  "if (jsonData.token) {",
                  "  pm.environment.set('token', jsonData.token);",
                  "  pm.collectionVariables.set('token', jsonData.token);",
                  "}",
                  "",
                  "if (jsonData.refreshToken) {",
                  "  pm.environment.set('refresh_token', jsonData.refreshToken);",
                  "  pm.collectionVariables.set('refresh_token', jsonData.refreshToken);",
                  "}",
                  "",
                  "if (jsonData.id) {",
                  "  pm.environment.set('userId', String(jsonData.id));",
                  "  pm.collectionVariables.set('userId', String(jsonData.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{base_url}}/auth/login",
            "description": "Autentica al usuario y guarda automaticamente `token`, `refresh_token` y `userId` en variables de entorno y de coleccion."
          }
        },
        {
